generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String          @unique
  pinCode        String
  avatarUrl      String?
  backgroundUrl  String?
  shipData       String?
  food           Int             @default(0)
  routineRecords RoutineRecord[]
  strategyPosts  StrategyPost[]
  lockPlans      LockPlan[]
  dailyCheckIns  DailyCheckIn[]
  gameScores     GameScore[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Activity {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  routineRecords RoutineRecord[]
  strategyPosts  StrategyPost[]
  lockTags       LockTag[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isActive, sortOrder])
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      String
  reward    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model RoutineRecord {
  id          String   @id @default(cuid())
  userId      String
  activityId  String?
  seaArea     String
  missionName String
  airControl  Int
  note        String?
  imageUrl    String?
  fleetData   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([userId, seaArea])
  @@index([createdAt])
}

model StrategyPost {
  id              String   @id @default(cuid())
  userId          String
  activityId      String?
  phaseName       String
  title           String
  content         String
  fleetImageUrl   String?
  airbaseImageUrl String?
  routineCardIds  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activity Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([userId])
  @@index([phaseName])
  @@index([createdAt])
}

model LockTag {
  id         String     @id @default(cuid())
  activityId String?
  scopeKey   String     @default("daily")
  name       String
  colorClass String
  sortOrder  Int        @default(0)
  isActive   Boolean    @default(true)
  lockPlans  LockPlan[]
  activity   Activity?  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([scopeKey, name])
  @@index([activityId, sortOrder])
}

model LockPlan {
  id           String   @id @default(cuid())
  userId       String
  tagId        String
  assignedData String
  note         String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tag  LockTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  gameType  String   // "dino" | "survivor" | "invaders"
  score     Int      // 存活秒数
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameType, score(sort: Desc)])
  @@index([userId])
}
